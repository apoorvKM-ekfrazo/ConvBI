# ─────────────────────────────────────────────────────────────────
#  ConvBI  —  Environment Variables  (template — copy to .env)
# ─────────────────────────────────────────────────────────────────

# ── AI Provider Routing ───────────────────────────────────────────
# Provider failover order for all LLM calls:
# Supported values: groq, openai
AI_PROVIDER_ORDER=openai,groq

# OpenAI remains optional when ENABLE_OPENAI=false
ENABLE_OPENAI=true

# ── OpenAI (optional premium provider) ───────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_FALLBACK_MODEL=gpt-4.1-mini
OPENAI_COMPLEX_MODEL=gpt-4o
OPENAI_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_ALLOWED_MODELS=gpt-4o-mini,gpt-4.1-mini,gpt-4o

# ── Groq (hosted OSS models) ─────────────────────────────────────
GROQ_API_KEY=
GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant
GROQ_COMPLEX_MODEL=llama-3.3-70b-versatile

# ── Anthropic (Claude) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Databricks ───────────────────────────────────────────────────
DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── AWS S3 (optional — users can also enter credentials in the UI)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_S3_BUCKET=

# ── Server ───────────────────────────────────────────────────────
PORT=3001
